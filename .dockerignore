# Keep the build context lean AND keep secrets / session state out of the image.
# The .env*.example exception mirrors .gitignore (conventions.md).
.env
.env.*
!.env.example
.wa-session
node_modules
dist
# The backoffice SPA is built INSIDE the image (Dockerfile build stage); keep
# the local install/build out of the context — nested dirs aren't covered by
# the top-level node_modules/dist patterns above.
backoffice/node_modules
backoffice/dist
.git
tests
spikes
evals
docs
# Keep infra out of the (app) build context for leanness, BUT the backup sidecar
# image (infra/backup/Dockerfile, context = repo root) needs its two scripts —
# re-include them (the nested-exception pattern: re-include the dir, then the
# files). Without this the sidecar image fails to build (COPY: file not found).
infra/*
!infra/backup
infra/backup/*
!infra/backup/lib.sh
!infra/backup/backup.sh
.claude
*.log
