{
  "name": "ezra-backoffice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only operations console for Ezra — isolated frontend sub-package (mirrors infra/pulumi: own deps/lockfile/tsconfig, kept out of the app's strict-TS/DBOS-lint scope).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "ui:debug": "node scripts/ui-debug.mjs"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.4.1",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.1.0",
    "vitest": "4.1.8"
  }
}
