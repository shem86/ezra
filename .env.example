# Copy to .env for local development. Never commit .env.
# All of these are read ONLY by src/ops/config.ts (Zod-validated at startup).

# Dev Postgres from docker-compose.yml (journal + state + pgvector co-located).
DATABASE_URL=postgres://hh:hh@localhost:5432/hh_assistant

# Claude Console API key (Haiku routing + Sonnet reasoning).
ANTHROPIC_API_KEY=

# Langfuse tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional; defaults to https://cloud.langfuse.com
# LANGFUSE_BASE_URL=

# Independent (non-WhatsApp) alert channel bot token — picked at T10/T12.
ALERT_CHANNEL_TOKEN=

# WhatsApp session state dir (secret-class; gitignored; never backed up,
# never restored — re-pair via `pnpm pair --reset` on loss).
# Optional; defaults to .wa-session
# WA_SESSION_DIR=
