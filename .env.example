# Copy to .env for local development. Never commit .env.
# All of these are read ONLY by src/ops/config.ts (Zod-validated at startup).

# Dev Postgres from docker-compose.yml (journal + state + pgvector co-located).
DATABASE_URL=postgres://hh:hh@localhost:5432/hh_assistant

# Claude Console API key (Haiku routing + Sonnet reasoning).
ANTHROPIC_API_KEY=

# Voyage AI key (semantic-store embeddings, voyage-4-lite; T28).
# Free tier: first 200M tokens per account — ~two centuries at our volume.
VOYAGE_API_KEY=

# Model tiers (T30 router). Optional; defaults shown — override for T33
# cost retuning without a code change.
# CHEAP_MODEL_ID=claude-haiku-4-5-20251001
# REASONING_MODEL_ID=claude-sonnet-4-6

# Langfuse tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional; defaults to https://cloud.langfuse.com
# LANGFUSE_BASE_URL=

# Independent (non-WhatsApp) alert channel: Telegram bot (chosen at T12).
# Token from @BotFather; chat id of the builder's chat with the bot.
ALERT_CHANNEL_TOKEN=
ALERT_CHANNEL_CHAT_ID=

# External dead-man check (healthchecks.io-style): the process pings this URL
# on a schedule; the service alerts from OUTSIDE when pings stop.
DEADMAN_PING_URL=

# WhatsApp session state dir (secret-class; gitignored; never backed up,
# never restored — re-pair via `pnpm pair --reset` on loss).
# Optional; defaults to .wa-session
# WA_SESSION_DIR=

# How long a parked confirm-before action waits for approval before T37's
# sweep expires it (hours). Optional; default shown (Open Q1, resolved T34).
# APPROVAL_TTL_HOURS=12

# Calendar service account (T39, ADR-0004): base64 of the downloaded key
# JSON, one line. Generate with:  base64 -i <key-file>.json | tr -d '\n'
# Secret-class: signs as the agent's robot identity. Never commit.
GOOGLE_SA_KEY_B64=

# Per-owner calendar ids (ADR-0004 requester routing). For personal primary
# calendars the id is the Gmail address. Both calendars must be shared with
# the service account's email ("Make changes to events").
CALENDAR_ID_HUSBAND=
CALENDAR_ID_WIFE=

# --- Production only (T42; loadProductionConfig — pnpm dev doesn't need these) ---

# Sender JIDs per member, comma-separated (a member may appear both
# phone-shaped and as @lid — see docs/pairing.md). Ledger #12: the prompt
# maps these to husband/wife so the model attributes correctly.
# WA_JID_HUSBAND=15550001111@s.whatsapp.net,111222333@lid
# WA_JID_WIFE=15550002222@s.whatsapp.net

# Chat JIDs the bot serves, comma-separated (the household group; optionally
# the two DMs). HARD PRIVACY BOUNDARY on a personal number: chats not listed
# here are ignored entirely — never ingested, never in prompts or traces.
# WA_HOUSEHOLD_CONVERSATIONS=120363041234567890@g.us

# --- Backups (T17; read by infra/backup/*.sh, NOT by config.ts) ---
# Encrypted PITR (base backups + archived WAL) to S3. See infra/backup/README.md.
#
# S3 target — same AWS account/region as the EC2 host.
# BACKUP_S3_BUCKET=hh-assistant-backups-001467466089
# BACKUP_S3_PREFIX=pitr            # optional; default pitr
#
# Client-side encryption (age, asymmetric): the host holds ONLY the public
# recipient, so a host compromise cannot decrypt existing backups. Generate
# with `age-keygen` and store the PRIVATE key offline (never on the host,
# never in the backup) — it is needed only to RESTORE.
# BACKUP_AGE_RECIPIENT=age1...     # public key — required to back up
# BACKUP_AGE_IDENTITY=/path/to/age.key  # private key file — required to restore only
#
# Compose-internal Postgres connection for the backup sidecar uses standard
# libpq vars (PGHOST=postgres, PGUSER, PGPASSWORD) — see docker-compose.backup.yml.
#
# Replication role (V2_NOTES §6). A FRESH cluster baked by
# infra/backup/initdb-replication.sh gets a least-priv `hh_backup` role; point
# the sidecar at it with BACKUP_PGUSER=hh_backup. BACKUP_ROLE_PASSWORD sets that
# role's password (defaults to POSTGRES_PASSWORD on both the initdb side and the
# sidecar side, so a fresh box needs no extra secret). The EXISTING prod box is
# wired for `hh` (enable-replication.sh, T45) — leave both unset there.
# BACKUP_PGUSER=hh_backup
# BACKUP_ROLE_PASSWORD=
#
# Backup-freshness dead-man (V2_NOTES §6): a SECOND healthchecks.io check URL,
# distinct from DEADMAN_PING_URL (which watches the process). The freshness timer
# pings <url> when the latest base backup is within BACKUP_MAX_AGE_HOURS and
# <url>/fail when it's stale/missing; the check alerts from outside if the fresh
# ping stops. Read by infra/backup/freshness.sh inside the sidecar.
# BACKUP_FRESHNESS_PING_URL=https://hc-ping.com/<uuid>
# BACKUP_MAX_AGE_HOURS=30          # optional; default 30 (over the 24h cadence)

# Postgres superuser password for the production stack (docker-compose.prod.yml
# substitutes it into POSTGRES_PASSWORD + the app's DATABASE_URL). Not read by
# config.ts; it is the DB credential the compose file injects.
# POSTGRES_PASSWORD=
