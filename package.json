{
  "name": "hh-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:recovery": "vitest run tests/integration/steps.test.ts tests/integration/queue.test.ts tests/integration/handle-turn.test.ts tests/integration/scheduled.test.ts tests/integration/recovery.test.ts tests/integration/compaction.test.ts tests/integration/park-recovery.test.ts tests/integration/launch-recovery.test.ts tests/integration/send-class-recovery.test.ts",
    "lint": "eslint .",
    "eval": "node --env-file=.env ./node_modules/vitest/vitest.mjs run --config vitest.eval.config.ts",
    "dev": "tsc && node --env-file=.env dist/dev/main.js",
    "start": "tsc && node --env-file=.env dist/start.js",
    "migrate": "tsc && node --env-file=.env dist/memory/migrate-cli.js",
    "pair": "tsc && node --env-file-if-exists=.env dist/transport/pair-cli.js",
    "transport": "tsc && node --env-file-if-exists=.env dist/transport/runner-cli.js"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@types/pg": "8.20.0",
    "@types/qrcode-terminal": "0.12.2",
    "eslint": "10.4.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.82",
    "@dbos-inc/dbos-sdk": "4.19.8",
    "@dbos-inc/node-pg-datasource": "4.19.8",
    "ai": "6.0.199",
    "baileys": "7.0.0-rc13",
    "pg": "8.21.0",
    "qrcode-terminal": "0.12.0",
    "zod": "4.4.3"
  }
}
