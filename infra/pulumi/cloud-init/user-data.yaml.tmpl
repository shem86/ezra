#cloud-config
# hh-assistant (ezra) full-chain bootstrap — V2_NOTES §2 ("invoke
# provision-host.sh from cloud-init/user-data so a fresh box self-bootstraps").
#
# Collapses the hand-typed infra/runtime.md deploy into one declarative artifact.
# Runs as root on first boot of a FRESH box. End state: the hardened ezra process
# is up and connecting — the ONLY remaining manual step is WhatsApp QR pairing
# (`pnpm pair`), which is inherently interactive and (on the single household
# number) cannot be double-paired from a throwaway box.
#
# Double-at placeholders (see cloud-init/render.ts) are filled at `pulumi up`.
package_update: true
package_upgrade: true
packages:
  - ca-certificates
  - curl
  - jq
  - git
  - unzip
  - age

write_files:
  - path: /opt/ezra/bootstrap.sh
    permissions: "0750"
    owner: root:root
    content: |
      #!/usr/bin/env bash
      # Stages 1-7 of the full chain. Idempotent enough to re-run on a stuck boot.
      set -euo pipefail
      log() { printf '[ezra-bootstrap %s] %s\n' "$(date -u +%H:%M:%S)" "$*"; }

      REPO_URL="@@REPO_URL@@"
      REPO_REF="@@REPO_REF@@"
      EZRA_TAG="@@EZRA_TAG@@"
      AWS_REGION="@@AWS_REGION@@"
      SECRETS_MODE="@@SECRETS_MODE@@"
      SECRETS_PARAM="@@SECRETS_PARAM@@"
      AGE_KEY_PARAM="@@AGE_KEY_PARAM@@"
      SOPS_ENV_FILE="@@SOPS_ENV_FILE@@"
      DEPLOY_KEY_PARAM="@@DEPLOY_KEY_PARAM@@"
      TAILSCALE_AUTHKEY_PARAM="@@TAILSCALE_AUTHKEY_PARAM@@"
      REPO_DIR=/home/hh/hh-assistant

      # --- 1. host tooling: Docker engine + compose plugin, aws-cli -----------
      log "installing docker engine + compose plugin"
      install -m 0755 -d /etc/apt/keyrings
      curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
        | gpg --batch --yes --dearmor -o /etc/apt/keyrings/docker.gpg  # --batch --yes: re-run safe (no TTY overwrite prompt)
      chmod a+r /etc/apt/keyrings/docker.gpg
      . /etc/os-release
      echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu ${VERSION_CODENAME} stable" \
        > /etc/apt/sources.list.d/docker.list
      apt-get update -y
      apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin

      if ! command -v aws >/dev/null 2>&1; then
        log "installing aws-cli v2"
        curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o /tmp/awscli.zip
        ( cd /tmp && unzip -q awscli.zip && ./aws/install )
      fi

      # No host Node: the egress firewall reads the committed
      # infra/egress/allowlist.generated.txt, not `node render-allowlist.ts`
      # (V2_NOTES §4). All app `node` runs inside the container.

      # --- 2. clone the repo at the pinned ref ---------------------------------
      # Private repo: fetch a read-only deploy key from SSM (instance role) and
      # clone over SSH. Without DEPLOY_KEY_PARAM, fall back to an https clone
      # (works only for a public repo).
      CLONE_URL="${REPO_URL}"
      if [[ -n "${DEPLOY_KEY_PARAM}" ]]; then
        log "fetching read-only deploy key from SSM"
        install -d -m 700 /root/.ssh
        aws ssm get-parameter --name "${DEPLOY_KEY_PARAM}" --with-decryption \
          --region "${AWS_REGION}" --query Parameter.Value --output text > /root/.ssh/deploy_key
        chmod 600 /root/.ssh/deploy_key
        export GIT_SSH_COMMAND="ssh -i /root/.ssh/deploy_key -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new"
        # https://github.com/owner/repo.git -> git@github.com:owner/repo.git
        CLONE_URL="$(printf '%s' "${REPO_URL}" | sed -E 's#https://github.com/#git@github.com:#')"
      fi
      log "cloning ${CLONE_URL}@${REPO_REF}"
      if [[ ! -d "${REPO_DIR}/.git" ]]; then
        git clone "${CLONE_URL}" "${REPO_DIR}"
      fi
      git -C "${REPO_DIR}" fetch --tags --prune origin
      git -C "${REPO_DIR}" checkout --force "${REPO_REF}"

      # --- 3. login/OS baseline: the hh user, SSH lockdown, patching, hostname ---
      # provision-host.sh runs `sshd -t`, which needs the privilege-separation
      # dir; it isn't present in cloud-init's early-boot context, so create it.
      mkdir -p /run/sshd
      log "running provision-host.sh (login/OS baseline)"
      bash "${REPO_DIR}/infra/provision-host.sh"
      # The clone (stage 2) created /home/hh as root BEFORE provision-host added
      # the hh user, so adduser left /home/hh root-owned ("home dir already
      # exists, not touching"). Chown the whole home, not just the repo, or hh
      # can't write ~/.docker (the GHCR login below) etc.
      chown -R hh:hh /home/hh

      # --- 4. sudoers drop-in + egress systemd unit/timer ----------------------
      # This host-config block (install here + enable at §6 below) is the BASELINE
      # a fresh box gets. infra/host/reconcile-host-config.sh reproduces the same
      # artifact set idempotently for an *adopted*/drifted host that never ran
      # cloud-init (V2_NOTES §2/§5) — keep the two in sync when adding host units.
      log "installing sudoers drop-in + egress unit/timer"
      install -m 0440 -o root -g root "${REPO_DIR}/infra/host/sudoers-hh-ops" /etc/sudoers.d/hh-ops
      visudo -cf /etc/sudoers.d/hh-ops
      # Install EVERY egress unit the repo ships, not a hardcoded pair: main
      # carries the apply/refresh split (V2_NOTES §11) where hh-egress.timer has
      # Unit=hh-egress-refresh.service — install only the apply unit and the
      # timer refuses to start ("trigger unit not loaded"). The glob picks up
      # hh-egress.service + hh-egress-refresh.service (and any future siblings).
      install -m 0644 "${REPO_DIR}"/infra/egress/hh-egress*.service /etc/systemd/system/
      install -m 0644 "${REPO_DIR}/infra/egress/hh-egress.timer" /etc/systemd/system/hh-egress.timer
      # Backup scheduling (V2_NOTES §6): base-backup timer + freshness dead-man
      # timer. Run as the hh operator via the docker group (no sudo), so they
      # need no sudoers entry — install + enable below (after compose is up).
      install -m 0644 "${REPO_DIR}"/infra/backup/hh-backup-*.service /etc/systemd/system/
      install -m 0644 "${REPO_DIR}"/infra/backup/hh-backup-*.timer /etc/systemd/system/
      systemctl daemon-reload
      usermod -aG docker hh

      # --- 5. fetch secrets → /home/hh/hh-assistant/.env -----------------------
      # SEAM: SSM is the testable-now default (the box already has the instance
      # role; the GHCR PAT already lives in SSM). SOPS+age is the flagged
      # portable alternative (V2_NOTES §3) — confirm at review.
      log "materializing .env (secretsMode=${SECRETS_MODE})"
      case "${SECRETS_MODE}" in
        ssm)
          aws ssm get-parameter --name "${SECRETS_PARAM}" --with-decryption \
            --region "${AWS_REGION}" --query Parameter.Value --output text > "${REPO_DIR}/.env"
          ;;
        sops)
          aws ssm get-parameter --name "${AGE_KEY_PARAM}" --with-decryption \
            --region "${AWS_REGION}" --query Parameter.Value --output text > /root/.sops-age.key
          chmod 600 /root/.sops-age.key
          SOPS_AGE_KEY_FILE=/root/.sops-age.key \
            sops -d "${REPO_DIR}/${SOPS_ENV_FILE}" > "${REPO_DIR}/.env"
          shred -u /root/.sops-age.key
          ;;
        *) log "unknown SECRETS_MODE=${SECRETS_MODE}"; exit 1 ;;
      esac
      chown hh:hh "${REPO_DIR}/.env"
      chmod 600 "${REPO_DIR}/.env"

      # --- 6. runtime: GHCR login → compose up → replication → egress ----------
      log "bringing up the hardened runtime (EZRA_TAG=${EZRA_TAG})"
      GHCR_PAT="$(aws ssm get-parameter --name /hh-assistant/ghcr-pat --with-decryption --region "${AWS_REGION}" --query Parameter.Value --output text)"
      printf '%s' "${GHCR_PAT}" | sudo -u hh docker login ghcr.io -u shem86 --password-stdin
      sudo -u hh env EZRA_TAG="${EZRA_TAG}" \
        docker compose --env-file "${REPO_DIR}/.env" -f "${REPO_DIR}/infra/docker-compose.prod.yml" pull
      sudo -u hh env EZRA_TAG="${EZRA_TAG}" \
        docker compose --env-file "${REPO_DIR}/.env" -f "${REPO_DIR}/infra/docker-compose.prod.yml" up -d
      # Replication on a FRESH box is already baked by initdb-replication.sh when
      # postgres first init'd its empty data dir (V2_NOTES §6), so this call is
      # now belt-and-suspenders / a no-op (idempotent). It still covers the case
      # of an existing pgdata volume reattached to a fresh box.
      sudo -u hh bash "${REPO_DIR}/infra/backup/enable-replication.sh" || log "replication wiring skipped/failed (non-fatal for first boot)"
      # Start the continuous WAL sidecar (the RPO-critical stream) + base/freshness
      # timers (V2_NOTES §6). The sidecar's `up -d` brings up the receivewal loop;
      # the timers fire the base backup (daily) and freshness check (hourly).
      sudo -u hh env EZRA_TAG="${EZRA_TAG}" \
        docker compose --env-file "${REPO_DIR}/.env" \
          -f "${REPO_DIR}/infra/docker-compose.prod.yml" \
          -f "${REPO_DIR}/infra/backup/docker-compose.backup.yml" up -d backup \
        || log "backup sidecar start skipped/failed (non-fatal for first boot)"
      systemctl enable --now hh-backup-base.timer hh-backup-freshness.timer || true
      # Boot-time apply FIRST (creates the nft table), THEN enable+start the
      # timer: its triggered refresh unit is After=hh-egress.service and only
      # swaps set elements on an already-loaded table, so the table must exist
      # before the timer's immediate (OnBootSec-already-elapsed + Persistent)
      # first firing.
      systemctl start hh-egress.service || true
      systemctl enable --now hh-egress.timer

      # --- 7. backoffice exposure: SELECT-only role password + Tailscale -------
      # 7a. Migration 0007 (applied by ezra at startup, main.ts runMigrations)
      # created hh_readonly passwordless. Set its password to match the
      # BACKOFFICE_DATABASE_URL in .env so the console can connect. Idempotent.
      BO_URL="$(grep -E '^BACKOFFICE_DATABASE_URL=' "${REPO_DIR}/.env" | head -1 | cut -d= -f2-)"
      if [[ -n "${BO_URL}" ]]; then
        log "waiting for the hh_readonly role (ezra applies migrations on launch)"
        for _ in $(seq 1 30); do
          if sudo -u hh docker exec hh-postgres-prod psql -U hh -d hh_assistant_prod -tAc \
               "SELECT 1 FROM pg_roles WHERE rolname='hh_readonly'" 2>/dev/null | grep -q 1; then break; fi
          sleep 2
        done
        # Decode the password from the URL (handles %xx) without shell quoting.
        RO_PW="$(U="${BO_URL}" node -e 'process.stdout.write(new URL(process.env.U).password)')"
        sudo -u hh docker exec hh-postgres-prod psql -U hh -d hh_assistant_prod \
          -c "ALTER ROLE hh_readonly LOGIN PASSWORD '${RO_PW}'" \
          && log "SELECT-only role password set from BACKOFFICE_DATABASE_URL"
      else
        log "BACKOFFICE_DATABASE_URL unset — skipping SELECT-only role password"
      fi

      # 7b. Tailscale: join the tailnet + serve the backoffice over HTTPS. No
      # public ingress (tailscaled dials OUT; the SG stays SSH-only). `tailscale
      # serve` fronts the loopback-bound backoffice (127.0.0.1:8787) with the
      # node's *.ts.net Let's Encrypt cert — MagicDNS + HTTPS must be enabled in
      # the tailnet admin console (Phase 0). Mirrors the live-host first-roll
      # (BO-22); on prod this whole file is ignoreChanges so it never re-runs.
      if [[ -n "${TAILSCALE_AUTHKEY_PARAM}" ]]; then
        log "installing tailscale + joining the tailnet"
        curl -fsSL https://tailscale.com/install.sh | sh
        TS_AUTHKEY="$(aws ssm get-parameter --name "${TAILSCALE_AUTHKEY_PARAM}" --with-decryption \
          --region "${AWS_REGION}" --query Parameter.Value --output text)"
        tailscale up --auth-key="${TS_AUTHKEY}" --hostname=ezra-backoffice
        tailscale serve --bg --https=443 http://127.0.0.1:8787
        log "tailscale up + serving the backoffice over HTTPS on the tailnet"
      else
        log "TAILSCALE_AUTHKEY_PARAM unset — skipping tailnet bootstrap"
      fi

      log "full-chain bootstrap complete — ezra + backoffice up; remaining manual step: WhatsApp pairing (pnpm pair)"

runcmd:
  - [ bash, /opt/ezra/bootstrap.sh ]

final_message: "ezra full-chain bootstrap finished after $UPTIME s — pair WhatsApp to go live"
